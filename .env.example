# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# This file is for the SERVER (Postgres) setup — see docs/run-server.md.
# For standalone/SQLite you don't need this; see docs/run-standalone.md.

# --- Database: your PostgreSQL (DB + role created via db/bootstrap.sql) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://DB_HOST:5432/session_ledger
SPRING_DATASOURCE_USERNAME=session_ledger
SPRING_DATASOURCE_PASSWORD=change-me
# For the bundled Postgres instead (docker compose --profile localpg up):
#   SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/session_ledger

# --- MCP auth: token Claude must send. Generate with: openssl rand -hex 24 ---
SESSION_LEDGER_MCP_TOKEN=change-me-to-a-random-token

# --- Public URL for card links (OPTIONAL) ---
# Leave unset and the link is derived from the host the request came in on (correct by default).
# Set it only behind a reverse proxy or when the public URL differs from what clients connect to.
#SESSION_LEDGER_WEB_BASE_URL=http://SERVER_HOST:8080
# CORS is only needed if the web UI is served from a DIFFERENT origin than the API
# (not the case in the default single-container setup):
#SESSION_LEDGER_CORS_ORIGINS=http://SERVER_HOST:8080

# --- Host port the app is exposed on ---
SERVER_PORT=8080

# --- Only used by the bundled Postgres (localpg profile) ---
POSTGRES_DB=session_ledger
POSTGRES_USER=session_ledger
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
